# Copy this file, edit local paths, then run:
#   set -a
#   source server/vllm_pair.env
#   set +a
#   bash server/start_vllm_pair.sh

PYTHON_BIN=/ABSOLUTE/PATH/TO/vllm0171/bin/python

SLM_MODEL=/ABSOLUTE/PATH/TO/Qwen3-1.7B
LLM_MODEL=/ABSOLUTE/PATH/TO/Qwen3-4B
SLM_SERVED_MODEL_NAME=qwen3-1.7b-slm
LLM_SERVED_MODEL_NAME=qwen3-4b-llm

SLM_PORT=8101
LLM_PORT=8102
SLM_CUDA_DEVICE=0
LLM_CUDA_DEVICE=1

SLM_GPU_MEMORY_UTILIZATION=0.75
LLM_GPU_MEMORY_UTILIZATION=0.75
SLM_MAX_MODEL_LEN=20000
LLM_MAX_MODEL_LEN=20000

DTYPE=bfloat16
TRUST_REMOTE_CODE=0
ENFORCE_EAGER=0
ENABLE_PREFIX_CACHING=0

# DCRH entropy extraction expects raw top-k scores in the vLLM path.
LOGPROBS_MODE=raw_logits
MAX_LOGPROBS=20

# Optional shared or role-specific templates.
CHAT_TEMPLATE=
SLM_CHAT_TEMPLATE=
LLM_CHAT_TEMPLATE=

# Optional extra args, for example:
# SLM_EXTRA_ARGS="--disable-log-requests"
# LLM_EXTRA_ARGS="--disable-log-requests"
SLM_EXTRA_ARGS=
LLM_EXTRA_ARGS=
